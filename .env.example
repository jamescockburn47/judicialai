# Copy this file to .env and fill in your values.
#
# ANTHROPIC_API_KEY
#   Required for AI citation validation (Sonnet + Opus).
#   Get a key at https://console.anthropic.com
#   Pay-as-you-go. A full analysis run costs approximately $0.50-$2.00.
#
# COURTLISTENER_API_TOKEN
#   Free registration at https://www.courtlistener.com/sign-in/
#   Once logged in: https://www.courtlistener.com/api/rest/v4/api-token-auth/
#   Provides full opinion text for retrieved cases (html_with_citations field).
#   The shared token below works for non-commercial use — replace with your own
#   if you intend to run high-volume queries.
#
# RUST_LOG — controls backend log verbosity

ANTHROPIC_API_KEY=your_key_here
COURTLISTENER_API_TOKEN=0fe05870bc7e6a0c9420e1a7b863a7a088d80993
RUST_LOG=bs_detector=info,tower_http=info
